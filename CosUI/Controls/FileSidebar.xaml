<UserControl x:Class="CosUI.Controls.FileSidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MouseDown="Root_MouseDown">
    <UserControl.Resources>
        <Style x:Key="SidebarListStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Hidden"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>
        <Style x:Key="SidebarItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="2,0,0,0"
                                Padding="16,7">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BorderActiveBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource PrimaryBlueBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SidebarItemStyleAccent" TargetType="ListBoxItem" BasedOn="{StaticResource SidebarItemStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="2,0,0,0"
                                Padding="16,7">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BorderActiveBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <DataTemplate x:Key="FileItemTemplate">
            <TextBlock Text="{Binding Name}"
                       FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextTrimming="CharacterEllipsis"/>
        </DataTemplate>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Background="{DynamicResource SidebarBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="40"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Scripts header -->
        <Grid Grid.Row="0" Margin="16,14,16,8">
            <TextBlock Text="SCRIPTS" FontSize="9" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextMutedBrush}"
                       VerticalAlignment="Center"/>
            <Button Content="+" HorizontalAlignment="Right"
                    Foreground="{DynamicResource TextSecondaryBrush}"
                    Background="Transparent" BorderThickness="0"
                    FontSize="16" Cursor="Hand" Padding="4,0"
                    Click="NewFile_Click"/>
        </Grid>

        <!-- Scripts list -->
        <Grid Grid.Row="1">
            <ListBox x:Name="ScriptList"
                     Style="{StaticResource SidebarListStyle}"
                     ItemContainerStyle="{StaticResource SidebarItemStyle}"
                     ItemTemplate="{StaticResource FileItemTemplate}"
                     SelectionChanged="ScriptList_SelectionChanged"
                     MouseDoubleClick="ScriptList_MouseDoubleClick"
                     MouseRightButtonUp="ScriptList_RightClick"/>
            <Canvas x:Name="ScriptRenameCanvas" IsHitTestVisible="False"/>
        </Grid>

        <!-- Divider 1 -->
        <Border Grid.Row="2" Height="1"
                Background="{DynamicResource BorderSubtleBrush}"
                Margin="0,4"/>

        <!-- AutoExec header -->
        <Grid Grid.Row="3" Margin="16,8,16,8">
            <TextBlock Text="AUTOEXEC" FontSize="9" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextMutedBrush}"
                       VerticalAlignment="Center"/>
            <Button Content="+" HorizontalAlignment="Right"
                    Foreground="{DynamicResource TextSecondaryBrush}"
                    Background="Transparent" BorderThickness="0"
                    FontSize="16" Cursor="Hand" Padding="4,0"
                    Click="NewAutoExecFile_Click"/>
        </Grid>

        <!-- AutoExec list -->
        <Grid Grid.Row="4">
            <ListBox x:Name="AutoExecList"
                     Style="{StaticResource SidebarListStyle}"
                     ItemContainerStyle="{StaticResource SidebarItemStyleAccent}"
                     ItemTemplate="{StaticResource FileItemTemplate}"
                     SelectionChanged="AutoExecList_SelectionChanged"
                     MouseDoubleClick="AutoExecList_MouseDoubleClick"
                     MouseRightButtonUp="AutoExecList_RightClick"/>
            <Canvas x:Name="AutoExecRenameCanvas" IsHitTestVisible="False"/>
        </Grid>

        <!-- Divider 2 -->
        <Border Grid.Row="5" Height="1"
                Background="{DynamicResource BorderSubtleBrush}"
                Margin="0,4"/>

        <!-- Clients header -->
        <Grid Grid.Row="6" Margin="16,8,16,8">
            <TextBlock Text="CLIENTS" FontSize="9" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextMutedBrush}"
                       VerticalAlignment="Center"/>
            <TextBlock x:Name="ClientCountLabel" FontSize="9"
                       Foreground="{DynamicResource TextMutedBrush}"
                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </Grid>

        <!-- Clients list -->
        <ItemsControl x:Name="ClientList" Grid.Row="7" Margin="0,0,0,12">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border x:Name="ClientRow" Padding="12,5" Background="Transparent">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse Grid.Column="0" Width="6" Height="6"
                                     Fill="{DynamicResource StatusOnBrush}"
                                     Margin="4,0,8,0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock FontSize="9" Foreground="{DynamicResource TextMutedBrush}">
                                    <Run Text="PID "/><Run Text="{Binding Pid}"/>
                                </TextBlock>
                            </StackPanel>
                            <Button Grid.Column="2" Content="Kill"
                                    Style="{StaticResource GhostBtnStyle}"
                                    FontSize="9" Padding="6,2"
                                    Tag="{Binding Pid}"
                                    Click="KillClient_Click"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Custom context menu popup -->
        <Popup x:Name="CtxPopup" StaysOpen="False" AllowsTransparency="True"
               PlacementTarget="{Binding ElementName=RootGrid}">
            <Border Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderActiveBrush}"
                    BorderThickness="1" CornerRadius="6"
                    Padding="0,4" MinWidth="120">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.5" Color="{DynamicResource Shadow}"/>
                </Border.Effect>
                <StackPanel>
                    <Border x:Name="CtxRename" Padding="16,8" Cursor="Hand"
                            MouseLeftButtonUp="CtxRename_Click">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource BorderActiveBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="Rename" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Border>
                    <Border Height="1" Background="{DynamicResource BorderSubtleBrush}" Margin="8,2"/>
                    <Border x:Name="CtxDelete" Padding="16,8" Cursor="Hand"
                            MouseLeftButtonUp="CtxDelete_Click">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource BorderActiveBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="Delete" FontSize="12"
                                   Foreground="{DynamicResource TextErrorBrush}"/>
                    </Border>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
